# Runtime
NODE_ENV=development

# Institution
INSTITUTION_NAME="Your Institution Name"

# Database
DATABASE_URL=postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Cache
REDIS_URL=rediss://xxx.upstash.io:6380
REDIS_TOKEN=xxx

# Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# LLM
GOOGLE_AI_API_KEY=
GROQ_API_KEY=gsk_...

# TTS
KOKORO_API_URL=https://voz-kokoro.fly.dev
KOKORO_API_KEY=

# Embeddings
OPENAI_API_KEY=sk-...

# RAG Pipeline
RAG_CHUNK_SIZE=220
RAG_CHUNK_OVERLAP=40
RAG_EMBEDDING_VERSION=1
RAG_EMBEDDING_MODEL=text-embedding-3-small

# Abuse controls and provider guardrails
RATE_LIMIT_VOICE_TURN_WINDOW_SECONDS=60
RATE_LIMIT_VOICE_TURN_MAX_REQUESTS=30
RATE_LIMIT_WS_WINDOW_SECONDS=60
RATE_LIMIT_WS_MAX_REQUESTS=40
RATE_LIMIT_RAG_WINDOW_SECONDS=60
RATE_LIMIT_RAG_MAX_REQUESTS=10

VOICE_PIPELINE_MAX_RETRIES=2
PROVIDER_TIMEOUT_STT_MS=15000
PROVIDER_TIMEOUT_EMBED_MS=12000
PROVIDER_TIMEOUT_LLM_MS=20000
PROVIDER_TIMEOUT_TTS_MS=15000

# Storage (R2)
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=voz-audio
CLOUDFLARE_R2_PUBLIC_URL=https://audio.your-domain.pages.dev

# Cloudflare Worker
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Optional compatibility aliases (only if your older env still uses these keys)
CLERK_PUBLISHABLE_KEY=pk_test_xxx
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx
KOKORO_FLY_URL=https://voz-kokoro.fly.dev
WHATSAPP_QUEUE_NAME=whatsapp-audio
