{
  "name": "@voz/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "next build",
    "start": "next start -p 4000",
    "lint": "next lint",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run -c vitest.config.ts",
    "format": "prettier --check .",
    "worker": "dotenv -e .env -- tsx src/queue/workers/whatsapp-audio.worker.ts",
    "worker:rag-ingest": "dotenv -e .env -- tsx src/queue/workers/rag-ingest.worker.ts",
    "worker:rag-embed": "dotenv -e .env -- tsx src/queue/workers/rag-embed.worker.ts",
    "ws": "dotenv -e .env -- tsx src/realtime/server.ts",
    "start:worker": "NODE_ENV=production dotenv -e .env -- tsx src/queue/workers/whatsapp-audio.worker.ts",
    "start:worker:rag-ingest": "NODE_ENV=production dotenv -e .env -- tsx src/queue/workers/rag-ingest.worker.ts",
    "start:worker:rag-embed": "NODE_ENV=production dotenv -e .env -- tsx src/queue/workers/rag-embed.worker.ts",
    "start:ws": "NODE_ENV=production dotenv -e .env -- tsx src/realtime/server.ts"
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.2",
    "@clerk/nextjs": "^6.8.2",
    "@voz/ai-engine": "workspace:*",
    "@upstash/redis": "^1.34.3",
    "@voz/db": "workspace:*",
    "@voz/shared": "workspace:*",
    "bullmq": "^5.34.6",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.1",
    "next": "^15.1.0",
    "openai": "^4.76.0",
    "pino": "^9.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/ws": "^8.5.13",
    "dotenv-cli": "^7.4.2",
    "eslint-config-next": "^15.1.0",
    "tsx": "^4.19.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.8"
  }
}
